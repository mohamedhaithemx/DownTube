# DownTube — ZET Dev
# احصل على مفتاح Groq API مجاناً من: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

WHISPER_MODEL_SIZE=medium
WHISPER_MODEL_DIR=./models/whisper
SUBTITLE_MAX_LINES=2
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
TEMP_DIR=/tmp/downtube
FILE_TTL_MINUTES=10
MAX_DURATION_SECONDS=7200
MAX_DURATION_VIDEO_SUBTITLE=14400
MAX_DURATION_SINGLE=0
BASIC_TIMEOUT_SECONDS=15
INFO_TIMEOUT_SECONDS=60
RATE_LIMIT=10/minute
PORT=8080
